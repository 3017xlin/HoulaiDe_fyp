"{\n    \"scenario\": \"During a meeting to discuss our project's progress, my colleague accused me of not working hard enough in front of the team.\",\n    \"qa_pairs\": [\n        {\n            \"Variable\": \"How much does the text express negativity?\",\n            \"Question\": \"How did the accusation make you feel?\",\n            \"Answer\": \"It felt very negative.\",\n            \"Reason\": \"Accusations typically evoke negative emotions.\"\n        },\n        {\n            \"Variable\": \"To what extent does the text express anger?\",\n            \"Question\": \"What was your initial reaction to the accusation?\",\n            \"Answer\": \"I felt angry and defensive.\",\n            \"Reason\": \"Being accused can trigger feelings of anger.\"\n        },\n        {\n            \"Variable\": \"To what extent is there a lack of self-esteem fulfilment?\",\n            \"Question\": \"How did the accusation affect your self-esteem?\",\n            \"Answer\": \"It lowered my self-esteem.\",\n            \"Reason\": \"Accusations can undermine self-worth.\"\n        },\n        {\n            \"Variable\": \"To what extent is there a lack of communion fulfilment?\",\n            \"Question\": \"Did the accusation affect your relationship with your colleague?\",\n            \"Answer\": \"Yes, it damaged our relationship.\",\n            \"Reason\": \"Accusations can disrupt interpersonal connections.\"\n        },\n        {\n            \"Variable\": \"To what extent does the text express disappointment?\",\n            \"Question\": \"How did you feel about your colleague's accusation?\",\n            \"Answer\": \"I felt disappointed in them.\",\n            \"Reason\": \"Disappointment arises from unmet expectations in colleagues.\"\n        }\n    ]\n}"
"{\n    \"scenario\": \"Dea is always embarrassed to speak in class and always keeps quiet. Recently, she was informed by her teacher that her class participation grades are low and she needs to be more active to pass.\",\n    \"qa_pairs\": [\n        {\n            \"Variable\": \"To what extent is self-esteem fulfilled in the coding unit?\",\n            \"Question\": \"How does Dea feel about her speaking abilities?\",\n            \"Answer\": \"She feels inadequate and embarrassed.\",\n            \"Reason\": \"Her silence indicates low self-esteem in speaking.\"\n        },\n        {\n            \"Variable\": \"To what extent is there a lack of self-esteem fulfilment?\",\n            \"Question\": \"What contributes to Dea's reluctance to speak up?\",\n            \"Answer\": \"Fear of judgment and low confidence.\",\n            \"Reason\": \"Her embarrassment suggests a lack of self-esteem.\"\n        },\n        {\n            \"Variable\": \"How much does the text express fear?\",\n            \"Question\": \"What fears might Dea have about participating in class?\",\n            \"Answer\": \"Fear of making mistakes or being ridiculed.\",\n            \"Reason\": \"Her embarrassment indicates fear of negative evaluation.\"\n        },\n        {\n            \"Variable\": \"To what extent does the text express disappointment?\",\n            \"Question\": \"How might Dea feel about her participation grades?\",\n            \"Answer\": \"She feels disappointed in herself.\",\n            \"Reason\": \"Low grades likely lead to self-disappointment.\"\n        },\n        {\n            \"Variable\": \"To what extent is there a lack of communion fulfilment?\",\n            \"Question\": \"How connected does Dea feel with her classmates?\",\n            \"Answer\": \"She feels isolated and disconnected.\",\n            \"Reason\": \"Her silence suggests a lack of social connection.\"\n        }\n    ]\n}"
"{\n    \"scenario\": \"Yesterday, we handed in our project reports to the supervisor. I found out that a labmate scolded me in his report for a mistake that he believed I made, but it was actually his fault.\",\n    \"qa_pairs\": [\n        {\n            \"Variable\": \"How much does the text express negativity?\",\n            \"Question\": \"What negative feelings arise from the labmate's actions?\",\n            \"Answer\": \"Frustration and betrayal.\",\n            \"Reason\": \"The labmate's scolding creates feelings of unfairness.\"\n        },\n        {\n            \"Variable\": \"To what extent does the text express anger?\",\n            \"Question\": \"How angry do you feel about the labmate's report?\",\n            \"Answer\": \"Very angry.\",\n            \"Reason\": \"The unjust blame triggers strong feelings of anger.\"\n        },\n        {\n            \"Variable\": \"To what extent is there a lack of self-esteem fulfilment?\",\n            \"Question\": \"How has this incident affected your self-esteem?\",\n            \"Answer\": \"It has decreased my self-esteem.\",\n            \"Reason\": \"Being blamed unfairly impacts confidence negatively.\"\n        },\n        {\n            \"Variable\": \"To what extent does the text express disappointment?\",\n            \"Question\": \"How disappointed are you in your labmate?\",\n            \"Answer\": \"Extremely disappointed.\",\n            \"Reason\": \"The betrayal from a colleague is deeply disappointing.\"\n        },\n        {\n            \"Variable\": \"Is discord mentioned in the text?\",\n            \"Question\": \"What discord does this situation create in the team?\",\n            \"Answer\": \"Distrust among team members.\",\n            \"Reason\": \"Blame can lead to conflict and division.\"\n        }\n    ]\n}"
